--- !u!114 &127000399
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 127000397}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2b3c4d5e6f7a48902b3c4d5e6f7a4890, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InstructionSceneManager
  scriptText: {fileID: 1398847187}
  audioSource: {fileID: 0}
  voiceVolume: 1
  bgmSource: {fileID: 127000400}
  bgmClip: {fileID: 8300000, guid: d43d32667cf9f40cba1f9e300a0ca7aa, type: 3}
  bgmDelay: 3
  bgmLoop: 1
  bgmVolume: 0.3
  nextSceneName: GameScene
  initialDelay: 0.5
  endDelay: 1
  lines:
  - text: Welcome to Go with the Crow.
    voiceClip: {fileID: 8300000, guid: 4faca540d8fa4026bb9d9880d655bb9e, type: 3}
    holdDuration: 1.5
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: Here, all beings are crows.
    voiceClip: {fileID: 8300000, guid: 16a5b48ee75544538aa84ec62fd26d5f, type: 3}
    holdDuration: 2
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: "They spend their entire lives chasing oranges\u2014even tearing each other
      apart."
    voiceClip: {fileID: 8300000, guid: 3b53c15a8cc24720a0e60af74af46596, type: 3}
    holdDuration: 4.5
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: "Dear crow, among these bodies\u2026 can you find yourself?"
    voiceClip: {fileID: 8300000, guid: 3f815393d0de431086038a49f17584bd, type: 3}
    holdDuration: 4
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: Try moving around, or throw a punch.
    voiceClip: {fileID: 8300000, guid: 2b7133315455444e85b9e703ba6fd055, type: 3}
    holdDuration: 3.5
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: Good, just like that.
    voiceClip: {fileID: 8300000, guid: 2cad79a8c0574092be9e95958679e9c4, type: 3}
    holdDuration: 2.5
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: Strike an orange to claim it. Strike your kind to take from them.
    voiceClip: {fileID: 8300000, guid: b792def0014342f48456d3106f8584ac, type: 3}
    holdDuration: 4
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: Are you ready?
    voiceClip: {fileID: 8300000, guid: 40e4387ecc7e4f0c877ac39364c97988, type: 3}
    holdDuration: 1
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: Go plunder. Go hide. Take more oranges.
    voiceClip: {fileID: 8300000, guid: 0d55482688d6474f9ad9185a6a2f2250, type: 3}
    holdDuration: 4
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  - text: "If you\u2019re ready, press the attack button."
    voiceClip: {fileID: 8300000, guid: ce1b5027e2694957a70e35ec8faa6353, type: 3}
    holdDuration: 4
    fadeInDuration: 0.4
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
  introCharacters:
  - {fileID: 127000401}
  - {fileID: 127000402}
  - {fileID: 127000403}
  - {fileID: 127000404}
  introLineIndex: 0
  introWalkDuration: 5
  introOffscreenOffsetX: -15
  introWalkYaw: -90
  introRestYaw: 0
  animatorMovingBool: IsMoving
